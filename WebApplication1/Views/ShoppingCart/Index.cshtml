@model WebApplication1.Models.ShoppingCart

@{
    ViewData["Title"] = "Giỏ hàng";
}

<h1>Giỏ hàng</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-warning">@TempData["Message"]</div>
}

@if (Model.Items == null || !Model.Items.Any())
{
    <div class="alert alert-info">Giỏ hàng đang trống.</div>
    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Tiếp tục mua sắm</a>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price</td>
                        <td>@item.Quantity</td>
                        <td>@(item.Price * item.Quantity)</td>
                        <td>
                            <a asp-controller="ShoppingCart" asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="btn btn-sm btn-danger">
                                <i class="bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>Tổng: @Model.TotalPrice</h4>
        <div>
            <a class="btn btn-outline-secondary me-2" asp-controller="Home" asp-action="Index">Tiếp tục mua sắm</a>
            <a class="btn btn-success" asp-controller="ShoppingCart" asp-action="Checkout">Thanh toán</a>
        </div>
    </div>
}
