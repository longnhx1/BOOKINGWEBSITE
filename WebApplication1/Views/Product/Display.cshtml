@model Product
@using WebApplication1.Models

@{
    ViewData["Title"] = "Product Details";
}

@section Styles
{
    <link rel="stylesheet" href="~/css/ecommerce/product-display.css" asp-append-version="true" />
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index">Home</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Product" asp-action="Index">Products</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<div class="product-detail-header">
    <div>
        <h1 class="product-detail-title">@Model.Name</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Category?.Name))
        {
            <div class="mt-2">
                <span class="product-chip">@Model.Category!.Name</span>
            </div>
        }
    </div>

    <div class="d-flex gap-2">
        @if (User.IsInRole(SD.Role_Admin))
        {
            <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="Product" asp-action="Index">Quay lại Admin</a>
            <a class="btn btn-primary btn-sm" asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@Model.Id">Manage</a>
        }
        else
        {
            <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Quay lại danh sách</a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="border rounded p-3">
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="Product image" class="img-fluid rounded" />
            }
            else
            {
                <div class="border rounded p-4 text-muted text-center">Chưa có ảnh</div>
            }
        </div>
    </div>
    <div class="col-md-7">
        <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="product-price-badge">@Model.Price</span>
            <span class="text-muted">Giá niêm yết</span>
        </div>

        <div class="mt-3">
            <div class="fw-bold mb-2">Thông tin nổi bật</div>
            <div class="product-description">@Model.Description</div>
        </div>

        <div class="action-row">
            <button class="btn btn-primary" type="button" disabled>Thêm vào giỏ (sắp có)</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Xem thêm sản phẩm</a>
        </div>
    </div>
</div>
